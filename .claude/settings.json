{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Task",
      "Agent",
      "Skill",
      "AskUserQuestion",
      "SendMessage",
      "TeamCreate",
      "TeamDelete",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "mcp__jira__*",
      "mcp__playwright__*",
      "mcp__github__*",
      "mcp__telegram__*",
      "mcp__MCP_DOCKER__*",
      "mcp__claude-in-chrome__*"
    ],
    "deny": [
      "Bash(find:*-exec::*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/sync-dotfiles.sh pull",
            "timeout": 20,
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-destructive.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/activity-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/activity-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/activity-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-pane.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/eslint-check.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/activity-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-sound.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/sync-dotfiles.sh push",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "language": "Español",
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "mcpServers": {
    "jira": {
      "command": "npx",
      "args": [
        "-y",
        "jira-mcp"
      ],
      "env": {
        "JIRA_BASE_URL": "https://diego-moncada.atlassian.net",
        "JIRA_USER_EMAIL": "dfmoncada@gmail.com",
        "JIRA_EMAIL": "dfmoncada@gmail.com",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
        "JIRA_TYPE": "cloud",
        "JIRA_AUTH_TYPE": "basic"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--vision"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "telegram": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-telegram-agent"
      ],
      "env": {
        "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
        "TELEGRAM_CHAT_ID": "${TELEGRAM_CHAT_ID}"
      }
    }
  }
}
