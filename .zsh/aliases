# vim:ft=zsh

# Core
alias vim=nvim
alias v=vim
alias e=exit
alias h=history
alias t=tmux
alias mux=tmuxinator
alias l='ls -F'
alias ll='ls -laF'
alias prettyjson='python3 -m json.tool'

# Git (use `command git` to avoid shell function conflicts)
alias g='command git'
alias gs='command git status -s'
alias o='command git oneline'
alias oo='command git oneline -10'
alias groot='cd $(command git rev-parse --show-toplevel 2>/dev/null || echo ".")'

# Editors/configs
alias zshrc="$EDITOR $HOME/.zshrc"
alias vimrc="$EDITOR $HOME/.config/nvim/init.lua"
alias tmuxrc="$EDITOR $HOME/.tmux.conf"

# Docker
alias dc='docker compose'
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dlogs='docker compose logs -f --tail=50'

# Claude/OpenCode
alias claude='command claude'

# Clipboard (cross-platform)
if [[ "$IS_MACOS" == "1" ]]; then
  alias clip='pbcopy'
  alias paste='pbpaste'
else
  alias clip='xclip -selection clipboard'
  alias paste='xclip -selection clipboard -o'
fi

# Global aliases
alias -g G="|grep"
alias -g H="|head"
alias -g L="|less"
alias -g W="|wc -l"
alias -g J="|python3 -m json.tool"

# Nocorrect
alias npm='nocorrect npm'
